# KidFlow backend local development.
# Copy to `.env` for local use. Never commit real secrets.

SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_ANON_KEY=replace-with-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# Cloud sandbox values are Phase 0 only and must use synthetic data.
SUPABASE_PROJECT_REF=replace-with-sandbox-project-ref
SUPABASE_DB_PASSWORD=replace-with-local-only-db-password

# Stripe remains test mode only until production is approved.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
